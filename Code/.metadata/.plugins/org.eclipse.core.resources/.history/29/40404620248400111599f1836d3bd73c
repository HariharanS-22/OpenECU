int _write(int file, char *ptr, int len)
{
  (void)file;
  int DataIdx;

  for (DataIdx = 0; DataIdx < len; DataIdx++)
  {
	  ITM_SendChar(*ptr++);
  }
  return len;
}

int main(void)
{
	//Initialization
	SysTick_config();
	CAN1_Init();
	CAN1_LoopBack();

	uint32_t now = 0;

	char *MSG = "OpenECU";
	uint8_t len = strlen(MSG);
	uint8_t buf[9] = {0};

	while(1){
		if((sysTick - now) >= 1000){
			printf("1 sec passed!\n\r");
			CAN1_TxMsg((uint8_t *)MSG, len);
			now = sysTick;
		}

		if(flag_msgReceived){
			memcpy(buf, &receivedMsg, receivedDLC);
			buf[receivedDLC] = '\0';
			printf("Received from ISR: %s\n\r",buf);
			flag_msgReceived = 0;
		}
	}
}
